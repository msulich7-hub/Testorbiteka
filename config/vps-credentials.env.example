# Skopiuj ten plik:  cp config/vps-credentials.env.example config/vps-credentials.env
# Uzupełnij hasło w vps-credentials.env — ten plik jest w .gitignore i NIE commituj go.

# SSH (typowo)
VPS_HOST=217.160.42.59
VPS_SSH_USER=root
VPS_SSH_PORT=22

# Hasło do konta SSH (wpisz tylko w vps-credentials.env)
VPS_SSH_PASSWORD=

# Opcjonalnie: identyfikator panelu hostingu (jeśli dotyczy)
VPS_PANEL_ACCOUNT=home-8307573

# Notatka (nie sekret)
VPS_LABEL=VPS test Ubuntu 24.04 (Berlin)
VPS_OS=Ubuntu 24.04
